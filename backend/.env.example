# Copy to .env and fill in real values.

# PostgreSQL connection string used by Prisma (CLI + runtime adapter).
DATABASE_URL="postgresql://aqualagoon:aqualagoon@localhost:5432/aqualagoon?schema=public"

# HTTP server
PORT=8800
HOST=0.0.0.0

# development | production | test
NODE_ENV=development

# pretty | json — controls log output format
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins (the frontend URL).
CORS_ORIGIN="http://localhost:3300"

# --- Auth -------------------------------------------------------------------
# Signing secrets — generate your own with `openssl rand -base64 48`.
JWT_ACCESS_SECRET="change-me-access-secret-at-least-32-characters-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-at-least-32-characters-long"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
JWT_RESET_TTL="30m"

# --- Uploads ----------------------------------------------------------------
UPLOAD_DIR="uploads"
UPLOAD_URL_PREFIX="/uploads"
# PUBLIC_URL="http://localhost:8800"

# --- Login rate limiting ----------------------------------------------------
LOGIN_RATE_MAX=5
LOGIN_RATE_WINDOW="1 minute"

# --- AWS S3 (optional) ------------------------------------------------------
# Set all four to store uploads in S3; leave blank to use local disk uploads.
# NEVER commit real credentials — keep them in your gitignored .env only.
AWS_S3_BUCKET_NAME=
AWS_S3_BUCKET_REGION=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
# Optional CDN / custom-domain base (no trailing slash), e.g. https://cdn.example.com
# AWS_S3_PUBLIC_URL=

# --- Frontend URL (used to build links inside emails) -----------------------
FRONTEND_URL="http://localhost:3300"

# --- Email (optional) -------------------------------------------------------
# Configure sending one of two ways (checked in this order):
#  1) Generic SMTP — set SMTP_HOST (+ port/secure/user/pass). Works with any SMTP
#     server, e.g. Gmail: host smtp.gmail.com, port 465, secure true, user/pass.
#  2) Provider shortcut — EMAIL_PROVIDER="gmail" (GMAIL_USER/GMAIL_APP_PASSWORD)
#     or "resend" (RESEND_API_KEY).
# If neither is set, emails are logged to the console in dev when
# EMAIL_DEV_FALLBACK=true (set false to skip sending instead).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional explicit sender; otherwise composed from EMAIL_FROM_NAME + EMAIL_FROM.
MAIL_FROM="Aqua Lagoon <no-reply@aqualagoon.com>"
EMAIL_PROVIDER=
RESEND_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=no-reply@aqualagoon.com
EMAIL_FROM_NAME=Aqua Lagoon
EMAIL_DEV_FALLBACK=true