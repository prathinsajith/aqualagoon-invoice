// Prisma schema — https://pris.ly/d/prisma-schema
// Prisma 7 uses the Rust-free query compiler and the `prisma-client` generator,
// which emits the client to an explicit `output` path inside the project.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// RBAC: roles, users, role/permission assignments, audit trail.
// ---------------------------------------------------------------------------

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  // System roles are seeded and cannot be deleted (they can be renamed/edited).
  isSystem    Boolean  @default(false) @map("is_system")
  // Admin-controlled display order (drag-to-reorder); lower shows first.
  displayOrder Int     @default(0) @map("display_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  // Role-assignment scope: which roles a member of THIS role may assign/view
  // when creating or listing users (configured by an admin in company settings).
  manages      RoleAssignableRole[] @relation("RoleManages")
  assignableBy RoleAssignableRole[] @relation("RoleAssignable")

  @@map("roles")
}

// Join table: a member of `role` may assign/manage users that hold
// `assignableRole`. Admins bypass this entirely (they manage every role).
model RoleAssignableRole {
  id               String @id @default(uuid())
  roleId           String @map("role_id")
  assignableRoleId String @map("assignable_role_id")

  role           Role @relation("RoleManages", fields: [roleId], references: [id], onDelete: Cascade)
  assignableRole Role @relation("RoleAssignable", fields: [assignableRoleId], references: [id], onDelete: Cascade)

  @@unique([roleId, assignableRoleId])
  @@index([roleId])
  @@map("role_assignable_roles")
}

model User {
  id           String     @id @default(uuid())
  userCode     String     @unique @map("user_code")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  // Optional: customer-type users (Guest/Student) may have no email. Login users
  // (Admin/Staff/Coach) always have one — enforced in the users service.
  email        String?    @unique
  phone        String?    @unique
  passwordHash String     @map("password_hash")
  gender       String?
  dateOfBirth  DateTime?  @map("date_of_birth")
  photoUrl     String?    @map("photo_url")
  address      String?
  status       UserStatus @default(ACTIVE)
  // Bumped on "logout from all devices" to invalidate every issued token.
  tokenVersion Int        @default(0) @map("token_version")
  // TOTP two-factor auth. Secret is encrypted at rest; enabled only after a
  // successful verification during setup.
  totpSecret   String?    @map("totp_secret")
  totpEnabled  Boolean    @default(false) @map("totp_enabled")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  // Soft delete: non-null means the user is archived.
  deletedAt    DateTime?  @map("deleted_at")

  userRoles     UserRole[]
  assignedRoles UserRole[] @relation("RoleAssignedBy")
  auditLogs     AuditLog[]
  recoveryCodes TwoFactorRecoveryCode[]
  userPasses    UserPass[]

  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  // Support sorting the user list by name / last login.
  @@index([firstName])
  @@index([lastName])
  @@index([lastLoginAt])
  @@map("users")
}

/**
 * Single-use 2FA recovery codes. Stored hashed (never plaintext); the plaintext
 * is shown to the user exactly once at generation time. A non-null usedAt marks
 * a code as spent.
 */
model TwoFactorRecoveryCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("two_factor_recovery_codes")
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("RoleAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  // Prevent duplicate role assignments.
  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model Permission {
  id     String @id @default(uuid())
  module String
  action String
  // Fully-qualified key, e.g. "user.create".
  name   String @unique

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // Prevent duplicate permission assignments.
  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  module    String
  recordId  String?  @map("record_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  // Fetch the history of a single record (e.g. a product's changes).
  @@index([recordId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Existing example resource (unchanged).
// ---------------------------------------------------------------------------

model Status {
  id        Int      @id @default(autoincrement())
  label     String
  colorCode String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Company profile — a single row holding org-wide branding/contact details
// (edited by admins under /company; used for app + email branding).
// ---------------------------------------------------------------------------

model CompanySetting {
  id        String   @id @default(uuid())
  name      String   @default("Aqua Lagoon")
  tagline   String?
  email     String?
  phone     String?
  website   String?
  address   String?
  logoUrl   String?  @map("logo_url")
  // Prefix for generated user codes, e.g. "USR" -> USR-A1B2C3.
  userCodePrefix String @default("USR") @map("user_code_prefix")
  // Prefix for generated invoice numbers, e.g. "INV" -> INV-2026-000001.
  invoicePrefix  String @default("INV") @map("invoice_prefix")
  // Prefix for generated pass numbers, e.g. "PASS" -> PASS-2026-000001.
  passPrefix     String @default("PASS") @map("pass_prefix")
  // ISO 4217 currency code used to format all money (e.g. INR, USD, AED).
  currency       String @default("INR")
  // App-wide date display format (e.g. DD/MM/YYYY, MM/DD/YYYY, YYYY-MM-DD).
  dateFormat     String @default("DD/MM/YYYY") @map("date_format")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

// ---------------------------------------------------------------------------
// Inventory: sellable physical products and the categories that group them.
// (Passes, memberships, fees and services are NOT modelled here — separate
// modules own those.)
// ---------------------------------------------------------------------------

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model ProductCategory {
  id          String        @id @default(uuid())
  // Human-friendly auto-generated code, e.g. "CAT-A1B2C3".
  code        String        @unique
  // Uniqueness is enforced in the service among non-deleted rows, so an archived
  // category's name can be reused (there is no category restore).
  name        String
  description String?
  status      ProductStatus @default(ACTIVE)
  // Lightweight stamps of the acting user (the audit log is the full history).
  createdBy   String?       @map("created_by")
  updatedBy   String?       @map("updated_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  // Soft delete: non-null means the category is archived.
  deletedAt   DateTime?     @map("deleted_at")

  products Product[]

  @@index([status])
  @@index([deletedAt])
  @@index([name])
  @@map("product_categories")
}

model Product {
  id            String        @id @default(uuid())
  // Auto-generated stock-keeping unit, e.g. "SKU-A1B2C3".
  sku           String        @unique
  // Optional scanner barcode; unique when present (Postgres allows many NULLs).
  barcode       String?       @unique
  categoryId    String        @map("category_id")
  name          String
  description   String?
  purchasePrice Decimal       @default(0) @map("purchase_price") @db.Decimal(12, 2)
  sellingPrice  Decimal       @map("selling_price") @db.Decimal(12, 2)
  taxPercentage Decimal       @default(0) @map("tax_percentage") @db.Decimal(5, 2)
  imageUrl      String?       @map("image_url")
  stockQuantity Int           @default(0) @map("stock_quantity")
  minimumStock  Int           @default(0) @map("minimum_stock")
  status        ProductStatus @default(ACTIVE)
  createdBy     String?       @map("created_by")
  updatedBy     String?       @map("updated_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  category              ProductCategory        @relation(fields: [categoryId], references: [id])
  inventoryTransactions InventoryTransaction[]

  @@index([categoryId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([name])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Billing & payments (POS). The invoice/items structure is deliberately generic
// so future billing modules (passes, training fees, memberships, services) plug
// in via `invoice_type` + polymorphic `invoice_items.item_type/item_id` — no
// schema redesign required.
// ---------------------------------------------------------------------------

enum InvoiceStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  CANCELLED
  REFUNDED
}

enum InvoiceType {
  PRODUCT
  PASS
  TRAINING
  MIXED
}

enum InvoiceItemType {
  PRODUCT
  PASS
  TRAINING
  SERVICE
  MEMBERSHIP
}

enum InventoryTransactionType {
  SALE
  SALE_REVERSAL
  ADJUSTMENT
  RESTOCK
  INITIAL
}

model PaymentMethod {
  id           String    @id @default(uuid())
  name         String
  description  String?
  isActive     Boolean   @default(true) @map("is_active")
  displayOrder Int       @default(0) @map("display_order")
  createdBy    String?   @map("created_by")
  updatedBy    String?   @map("updated_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  payments Payment[]

  @@index([isActive])
  @@index([deletedAt])
  @@index([displayOrder])
  @@map("payment_methods")
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNo      String        @unique @map("invoice_no")
  // Nullable — walk-in sales have no customer; a customer module can populate
  // this later without changing the schema.
  customerId     String?       @map("customer_id")
  invoiceType    InvoiceType   @default(PRODUCT) @map("invoice_type")
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceAmount  Decimal       @default(0) @map("balance_amount") @db.Decimal(12, 2)
  status         InvoiceStatus @default(PENDING)
  notes          String?
  createdBy      String?       @map("created_by")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  items      InvoiceItem[]
  payments   Payment[]
  userPasses UserPass[]

  @@index([status])
  @@index([invoiceType])
  @@index([createdAt])
  @@index([customerId])
  @@map("invoices")
}

model InvoiceItem {
  id             String          @id @default(uuid())
  invoiceId      String          @map("invoice_id")
  // Polymorphic line: item_type + item_id reference a product today, and
  // passes / training / memberships / services in future phases.
  itemType       InvoiceItemType @map("item_type")
  itemId         String          @map("item_id")
  itemName       String          @map("item_name")
  quantity       Int
  unitPrice      Decimal         @map("unit_price") @db.Decimal(12, 2)
  discountAmount Decimal         @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal         @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal         @map("total_amount") @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([itemType, itemId])
  @@map("invoice_items")
}

model Payment {
  id                   String   @id @default(uuid())
  invoiceId            String   @map("invoice_id")
  paymentMethodId      String   @map("payment_method_id")
  amount               Decimal  @db.Decimal(12, 2)
  transactionReference String?  @map("transaction_reference")
  remarks              String?
  receivedBy           String?  @map("received_by")
  paymentDate          DateTime @default(now()) @map("payment_date")
  createdAt            DateTime @default(now()) @map("created_at")

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([invoiceId])
  @@index([paymentMethodId])
  @@index([paymentDate])
  @@map("payments")
}

model InventoryTransaction {
  id             String                   @id @default(uuid())
  productId      String                   @map("product_id")
  type           InventoryTransactionType
  // Signed delta: negative for SALE, positive for RESTOCK / SALE_REVERSAL.
  quantityChange Int                      @map("quantity_change")
  balanceAfter   Int                      @map("balance_after")
  // Optional link to the document that caused the movement (e.g. invoice).
  referenceType  String?                  @map("reference_type")
  referenceId    String?                  @map("reference_id")
  notes          String?
  createdBy      String?                  @map("created_by")
  createdAt      DateTime                 @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

// Per-year counter for sequential invoice numbers (INV-YYYY-000001). Incremented
// atomically inside the checkout transaction.
model InvoiceSequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("invoice_sequences")
}

// ---------------------------------------------------------------------------
// Passes & memberships. Deliberately separate from products (different business
// rules: validity windows, entry limits, usage tracking). Sold through the same
// invoice/POS flow via invoice_items.item_type = PASS.
// ---------------------------------------------------------------------------

enum PassKind {
  GUEST
  STUDENT
  VIP
  FAMILY
  CORPORATE
}

enum PassDurationType {
  HOUR
  DAY
  MONTH
  YEAR
}

enum PassEntryType {
  LIMITED
  UNLIMITED
}

enum PassDiscountType {
  NONE
  FIXED
  PERCENTAGE
}

enum UserPassStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

model PassType {
  id           String        @id @default(uuid())
  type         PassKind
  name         String
  description  String?
  // Validity window: e.g. duration_type=HOUR, duration_value=2 → valid 2 hours.
  durationType PassDurationType @map("duration_type")
  durationValue Int             @map("duration_value")
  // Entry policy. allowedEntries / maxEntriesPerDay are null for UNLIMITED.
  entryType        PassEntryType @map("entry_type")
  allowedEntries   Int?          @map("allowed_entries")
  maxEntriesPerDay Int?          @map("max_entries_per_day")
  price            Decimal       @db.Decimal(12, 2)
  discountType     PassDiscountType @default(NONE) @map("discount_type")
  discountValue    Decimal          @default(0) @map("discount_value") @db.Decimal(12, 2)
  status           ProductStatus    @default(ACTIVE)
  createdBy        String?       @map("created_by")
  updatedBy        String?       @map("updated_by")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  userPasses UserPass[]

  @@index([type])
  @@index([status])
  @@index([deletedAt])
  @@map("pass_types")
}

model UserPass {
  id         String  @id @default(uuid())
  // Holder — null for a bearer pass sold to a walk-in customer.
  userId     String? @map("user_id")
  // Name captured at sale time — lets walk-in (no account) passes name a holder.
  holderName String? @map("holder_name")
  passTypeId String  @map("pass_type_id")
  // The invoice that sold this pass (null only for admin-issued passes).
  invoiceId  String? @map("invoice_id")
  // Auto-generated, e.g. "PASS-2026-000001".
  passNumber String  @unique @map("pass_number")

  startTime  DateTime @map("start_time")
  expiryTime DateTime @map("expiry_time")

  originalPrice  Decimal @map("original_price") @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(12, 2)
  finalAmount    Decimal @map("final_amount") @db.Decimal(12, 2)

  // Null for unlimited-entry passes; otherwise counts down on each entry.
  remainingEntries Int? @map("remaining_entries")

  status      UserPassStatus @default(PENDING)
  activatedAt DateTime?      @map("activated_at")
  createdBy   String?        @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  passType  PassType       @relation(fields: [passTypeId], references: [id])
  invoice   Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  usageLogs PassUsageLog[]
  renewals  PassRenewal[]

  @@index([userId])
  @@index([passTypeId])
  @@index([invoiceId])
  @@index([status])
  @@index([expiryTime])
  // List orders by and filters on createdAt (date-range filter, dashboard aggregates).
  @@index([createdAt])
  @@map("user_passes")
}

model PassUsageLog {
  id         String    @id @default(uuid())
  userPassId String    @map("user_pass_id")
  // Denormalized holder reference (the pass already links to the user).
  userId     String?   @map("user_id")
  entryTime  DateTime  @default(now()) @map("entry_time")
  exitTime   DateTime? @map("exit_time")
  remarks    String?
  createdAt  DateTime  @default(now()) @map("created_at")

  userPass UserPass @relation(fields: [userPassId], references: [id], onDelete: Cascade)

  @@index([userPassId])
  @@index([entryTime])
  @@map("pass_usage_logs")
}

model PassRenewal {
  id                 String   @id @default(uuid())
  userPassId         String   @map("user_pass_id")
  previousExpiryTime DateTime @map("previous_expiry_time")
  newExpiryTime      DateTime @map("new_expiry_time")
  renewedBy          String?  @map("renewed_by")
  renewedAt          DateTime @default(now()) @map("renewed_at")

  userPass UserPass @relation(fields: [userPassId], references: [id], onDelete: Cascade)

  @@index([userPassId])
  @@map("pass_renewals")
}

// Per-year counter for sequential pass numbers (PASS-YYYY-000001).
model PassSequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("pass_sequences")
}
